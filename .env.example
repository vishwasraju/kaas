# Gemini AI API Key (required)
GEMINI_API_KEY=your_api_key_here

# Gemini model to use (optional, defaults to gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Maximum retry attempts for Gemini API calls (optional, defaults to 3)
# GEMINI_MAX_RETRIES=3

# Maximum upload file size in MB (optional, defaults to 50)
# MAX_UPLOAD_SIZE_MB=50

# Chunking settings for large documents (optional)
# GEMINI_BATCH_SIZE_PAGES=15
# GEMINI_BATCH_OVERLAP_PAGES=1
# GEMINI_BATCH_DELAY_SEC=1.0

# Logging level (optional, defaults to INFO)
# LOG_LEVEL=INFO

